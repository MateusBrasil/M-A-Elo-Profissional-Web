# M&A Elo Profissional — Vercel environment variables
# Copy this file as a checklist of what to configure in Vercel Project Settings → Environment Variables.
# DO NOT commit the real .env file.

# --- Neon connections (server-side only) ---
# Owner connection — used by admin endpoints (full access)
NEON_OWNER_CONN=postgresql://neondb_owner:CHANGE_ME@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Low-privilege connection — used by public form submissions (INSERT into candidatos, SELECT formularios)
NEON_FORM_CONN=postgresql://form_user:CHANGE_ME@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Admin auth ---
# Email allowed to log in
ADMIN_EMAIL=admin@maelo.pt

# Initial PBKDF2 hash of the admin password — only used on first boot to seed admin_users.
# Generate with:  node scripts/hash-password.js "your-strong-password"
# Format: pbkdf2$200000$<saltB64>$<hashB64>
ADMIN_PASSWORD_HASH=pbkdf2$200000$REPLACE_WITH_GENERATED_SALT$REPLACE_WITH_GENERATED_HASH

# Secret used to sign session and reset tokens (HMAC-SHA256). Use a random 64+ char string.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET

# --- Optional: email delivery (password reset) ---
# Resend API key — if absent, the reset link is printed to Vercel logs (manual fallback).
# Sign up at https://resend.com — verify a domain and create an API key.
RESEND_API_KEY=
RESET_FROM_EMAIL=M&A Elo <noreply@your-verified-domain.com>

# --- Optional: base URL used in reset emails (defaults to request origin) ---
PUBLIC_BASE_URL=https://m-a-elo-profissional-web.vercel.app
