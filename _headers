# ═══════════════════════════════════════════════════════════
# Cloudflare Pages — Headers config (M&A Elo Profissional)
# Mais específico primeiro (assets, css, js, admin) → /* catch-all.
# Inclui candidaturas.maelo.pt como subdomínio de formulários.
# ═══════════════════════════════════════════════════════════

# ─── Static assets (1 ano cache imutável) ─────────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ─── CSS files (1 dia + SWR 7 dias) ───────────────────────
/*.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# ─── JS files (1 dia + SWR 7 dias) ────────────────────────
/*.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

# ─── Admin pages (CSP relaxada para inline scripts + noindex) ──
/admin.html
  X-Robots-Tag: noindex, nofollow
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://candidaturas.maelo.pt; frame-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://candidaturas.maelo.pt; upgrade-insecure-requests;
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

/admin-reset.html
  X-Robots-Tag: noindex, nofollow

# ─── Security headers (todas as restantes páginas) ────────
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-WZRJfWvsnNCPcxzZwvyhovnZGqhZaC+8gPGPRbx6wTk=' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://tiles.openfreemap.org https://*.openfreemap.org; worker-src 'self' blob:; connect-src 'self' https://tiles.openfreemap.org https://*.openfreemap.org https://candidaturas.maelo.pt; frame-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://candidaturas.maelo.pt; upgrade-insecure-requests;
